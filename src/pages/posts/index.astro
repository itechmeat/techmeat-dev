---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import { defaultLocale } from "../../i18n/config";
import { t } from "../../i18n/t";
import { isVisiblePost } from "../../lib/postVisibility";

const locale = defaultLocale;
const heading = t("posts.archiveHeading", locale);
const description = t("posts.archiveDescription", locale);

const all = await getCollection("posts", ({ data }) => data.locale === locale && isVisiblePost(data));
const sorted = all.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout title={`${heading} — techmeat.dev`} description={description} ogImage="/posters/og/pages/posts.png">
  <h1>{heading}</h1>
  <ul class="post-list">
    {
      sorted.map((entry) => {
        const slug = entry.id.split("/")[0];
        return (
          <li>
            <PostCard
              href={`/posts/${slug}`}
              title={entry.data.title}
              description={entry.data.description}
              pubDate={entry.data.pubDate}
              locale={locale}
            />
          </li>
        );
      })
    }
  </ul>
</BaseLayout>
