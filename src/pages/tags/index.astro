---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { defaultLocale } from "../../i18n/config";
import { t } from "../../i18n/t";
import { tagLabel } from "../../i18n/tags";
import { isVisiblePost } from "../../lib/postVisibility";

const locale = defaultLocale;
const heading = t("tags.indexHeading", locale);

const all = await getCollection("posts", ({ data }) => data.locale === locale && isVisiblePost(data));
const counts = new Map<string, number>();
for (const entry of all) {
  for (const tag of entry.data.tags ?? []) counts.set(tag, (counts.get(tag) ?? 0) + 1);
}
const tags = Array.from(counts.entries()).sort(
  (a, b) => b[1] - a[1] || a[0].localeCompare(b[0]),
);
---

<BaseLayout title={`${heading} — techmeat.dev`} description={heading} ogImage="/posters/og/pages/tags.png">
  <h1>{heading}</h1>
  <ul class="tag-list">
    {
      tags.map(([slug, count]) => (
        <li>
          <a href={`/tags/${encodeURIComponent(slug)}`}>#{tagLabel(slug, locale)}</a>
          <span class="tag-count">{count}</span>
        </li>
      ))
    }
  </ul>
</BaseLayout>
