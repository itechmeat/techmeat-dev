---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PostCard from "../../../components/PostCard.astro";
import { locales, defaultLocale, type Locale } from "../../../i18n/config";
import { t } from "../../../i18n/t";
import { tagLabel } from "../../../i18n/tags";
import { isVisiblePost } from "../../../lib/postVisibility";

export async function getStaticPaths() {
  const nonDefault = locales.filter((l) => l !== defaultLocale);
  const out: { params: { locale: Locale; tag: string } }[] = [];
  for (const locale of nonDefault) {
    const all = await getCollection("posts", ({ data }) => data.locale === locale && isVisiblePost(data));
    const tagSet = new Set<string>();
    for (const entry of all) for (const tag of entry.data.tags) tagSet.add(tag);
    for (const tag of tagSet) out.push({ params: { locale, tag } });
  }
  return out;
}

const locale = Astro.params.locale as Locale;
const tag = Astro.params.tag as string;
const localePrefix = `/${locale}`;

const all = await getCollection("posts", ({ data }) => data.locale === locale && isVisiblePost(data));
const matching = all
  .filter((entry) => entry.data.tags.includes(tag))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const label = tagLabel(tag, locale);
const heading = t("tags.heading", locale, { tag: label });
const keywords = label;
---

<BaseLayout
  title={`${heading} — techmeat.dev`}
  description={heading}
  locale={locale}
  keywords={keywords}
>
  <h1>{heading}</h1>
  <ul class="post-list">
    {
      matching.map((entry) => {
        const slug = entry.id.split("/")[0];
        return (
          <li>
            <PostCard
              href={`${localePrefix}/posts/${slug}`}
              title={entry.data.title}
              description={entry.data.description}
              pubDate={entry.data.pubDate}
              locale={locale}
            />
          </li>
        );
      })
    }
  </ul>
</BaseLayout>
