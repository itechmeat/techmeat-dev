---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PostCard from "../../../components/PostCard.astro";
import { locales, defaultLocale, type Locale } from "../../../i18n/config";
import { t } from "../../../i18n/t";
import { isVisiblePost } from "../../../lib/postVisibility";

export async function getStaticPaths() {
  return locales
    .filter((l) => l !== defaultLocale)
    .map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
const localePrefix = `/${locale}`;
const heading = t("posts.archiveHeading", locale);
const description = t("posts.archiveDescription", locale);

const all = await getCollection("posts", ({ data }) => data.locale === locale && isVisiblePost(data));
const sorted = all.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout title={`${heading} — techmeat.dev`} description={description} locale={locale}>
  <h1>{heading}</h1>
  <ul class="post-list">
    {
      sorted.map((entry) => {
        const slug = entry.id.split("/")[0];
        return (
          <li>
            <PostCard
              href={`${localePrefix}/posts/${slug}`}
              title={entry.data.title}
              description={entry.data.description}
              pubDate={entry.data.pubDate}
              tags={entry.data.tags}
              locale={locale}
            />
          </li>
        );
      })
    }
  </ul>
</BaseLayout>
