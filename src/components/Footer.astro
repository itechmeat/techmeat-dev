---
// src/components/Footer.astro
import { t } from "../i18n/t";
import type { Locale } from "../i18n/config";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const year = new Date().getFullYear();
const rssHref = locale === "en" ? "/rss.xml" : `/${locale}/rss.xml`;
---

<footer class="site-footer">
  <div class="site-footer-inner">
    <div class="left">
      <span>{t("footer.copyright", locale, { year })}</span>
      <span aria-hidden="true">·</span>
      <span>techmeat.dev</span>
    </div>
    <div class="right">
      <a
        href="https://github.com/itechmeat"
        target="_blank"
        rel="me noopener noreferrer">GitHub</a>
      <a href={rssHref} aria-label="RSS feed">RSS</a>
      {/* /privacy is English-only by design — link is identical from every locale */}
      <a href="/privacy">{t("footer.privacy", locale)}</a>
    </div>
  </div>
</footer>
