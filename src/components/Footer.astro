---
// src/components/Footer.astro
import { t } from "../i18n/t";
import type { Locale } from "../i18n/config";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const year = new Date().getFullYear();
---

<footer>
  <div class="left">
    <span>{t("footer.copyright", locale, { year })}</span>
    <span>· techmeat.dev</span>
  </div>
  <div class="right">
    <a href="https://github.com/itechmeat" rel="me" aria-label="GitHub">
      {/* placeholder text icon; replaced in design phase */}
      GH
    </a>
    {/* Twitter/X link added once handle is known. */}
    <a href={locale === "en" ? "/rss.xml" : `/${locale}/rss.xml`} aria-label="RSS feed">
      RSS
    </a>
    {/* /privacy is English-only by design — link is the same from every locale */}
    <a href="/privacy">{t("footer.privacy", locale)}</a>
  </div>
</footer>
