---
// src/components/Header.astro
import { t } from "../i18n/t";
import type { Locale } from "../i18n/config";
import ThemeToggle from "./islands/ThemeToggle.tsx";
import LanguageSwitcher from "./islands/LanguageSwitcher.tsx";

interface Props {
  locale: Locale;
  availableLocales?: Locale[];
  showLanguageSwitcher?: boolean;
  pathname?: string;
}

const {
  locale,
  availableLocales,
  showLanguageSwitcher = true,
  pathname = "/",
} = Astro.props;

const homeHref = locale === "en" ? "/" : `/${locale}/`;
const navPrefix = locale === "en" ? "" : `/${locale}`;

const navItems = [
  { href: `${navPrefix}/posts`, key: "nav.posts" as const },
  { href: `${navPrefix}/about`, key: "nav.about" as const },
  { href: `${navPrefix}/stack`, key: "nav.stack" as const },
];

function isActive(href: string): boolean {
  if (pathname === href || pathname === `${href}/`) return true;
  return pathname.startsWith(`${href}/`);
}
---

<header class="site-header">
  <div class="site-header-inner">
    <a href={homeHref} class="wordmark">techmeat.dev</a>
    <nav aria-label="Primary">
      <ul>
        {
          navItems.map((item) => {
            const active = isActive(item.href);
            return (
              <li>
                <a
                  href={item.href}
                  aria-current={active ? "page" : undefined}
                >
                  {t(item.key, locale)}
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>
    <div class="header-controls">
      <ThemeToggle client:load />
      {
        showLanguageSwitcher && (
          <LanguageSwitcher
            client:load
            currentLocale={locale}
            pathname={pathname}
            availableLocales={availableLocales}
          />
        )
      }
    </div>
  </div>
</header>
